# Copy this to `.env` and customize. All values are optional - defaults are sane.

# === LLM ===
# Model used for summarization and chat. Must be pulled via Ollama first.
LLM_MODEL=llama3.2

# Embedding model for vector search
EMBEDDING_MODEL=nomic-embed-text

# Sampling temperatures (0 = deterministic, higher = more creative)
LLM_TEMPERATURE=0
CHAT_TEMPERATURE=0.2

# === Chunking ===
SUMMARY_CHUNK_SIZE=10000
SUMMARY_CHUNK_OVERLAP=1000
CHAT_CHUNK_SIZE=600
CHAT_CHUNK_OVERLAP=120

# === Retrieval (MMR) ===
RETRIEVAL_K=4
RETRIEVAL_FETCH_K=20
RETRIEVAL_LAMBDA=0.5

# === Defaults ===
DEFAULT_DEPTH=standard
TRANSCRIPT_FETCH_RETRIES=3
